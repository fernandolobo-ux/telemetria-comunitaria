{
  "name": "Telemetria comunitaria",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",
  "features": {
    "ghcr.io/devcontainers/features/python:1": { "version": "3.11" }
  },
  "forwardPorts": [1883, 8086, 8000],
  "postCreateCommand": "pip install fastapi uvicorn paho-mqtt influxdb-client"
}
